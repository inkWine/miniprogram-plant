.container {
  min-height: 100vh;
  background-color: #F5F9F0;
  padding: 30rpx;
  box-sizing: border-box;
  padding-bottom: 140rpx;
}

/* 节气卡片 */
.term-card {
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  border-radius: 20rpx;
  padding: 40rpx;
  color: #fff;
  margin-bottom: 30rpx;
}
.term-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.term-name {
  font-size: 48rpx;
  font-weight: 700;
}
.term-date {
  font-size: 26rpx;
  opacity: 0.9;
}
.term-desc {
  font-size: 26rpx;
  line-height: 1.6;
  opacity: 0.95;
  margin-bottom: 30rpx;
}
.three-hou {
  background: rgba(255,255,255,0.15);
  border-radius: 12rpx;
  padding: 24rpx;
}
.hou-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.hou-item {
  font-size: 24rpx;
  line-height: 1.8;
  opacity: 0.95;
}
.hou-dot {
  margin-right: 12rpx;
  font-size: 20rpx;
}

/* 日历区域 */
.calendar-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}
.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}
.switch-btn {
  width: 60rpx;
  height: 60rpx;
  text-align: center;
  line-height: 60rpx;
  font-size: 36rpx;
  color: #2E7D32;
  font-weight: 600;
}
.month-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.week-row {
  display: flex;
  margin-bottom: 20rpx;
}
.week-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.day-grid {
  display: flex;
  flex-wrap: wrap;
}
.day-item {
  width: 14.28%;
  height: 90rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 10rpx;
}
.day-num {
  font-size: 26rpx;
  color: #333;
}
.other-month .day-num {
  color: #ccc;
}
.term-day {
  background-color: #E8F5E9;
  border-radius: 12rpx;
}
.term-day .day-num {
  color: #2E7D32;
  font-weight: 600;
}
.term-tag {
  font-size: 18rpx;
  color: #2E7D32;
  margin-top: 2rpx;
}
.today {
  border: 2rpx solid #2E7D32;
  border-radius: 12rpx;
}

/* 物候物种 */
.species-section {
  margin-bottom: 40rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}
.species-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.species-card {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  padding: 20rpx;
  gap: 20rpx;
}
.species-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.species-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.species-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}
.species-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 打卡按钮 */
.check-section {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
}
.check-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}
.check-btn.checked {
  background: #999;
}
.check-btn[disabled] {
  opacity: 0.8;
}