<view class="container">
  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <view class="search-input">
      <text class="search-icon">🔍</text>
      <input 
        placeholder="搜索物种、地点" 
        placeholder-class="placeholder"
        value="{{searchKey}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
        confirm-type="search"
      />
    </view>
  </view>

  <!-- 分类筛选标签 -->
  <scroll-view class="tab-scroll" scroll-x="true" show-scrollbar="{{false}}">
    <view class="tab-list">
      <view 
        wx:for="{{categoryList}}" 
        wx:key="id"
        class="tab-item {{currentCategory === item.id ? 'active' : ''}}"
        bindtap="switchCategory"
        data-id="{{item.id}}"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 观察列表 -->
  <view class="observe-list">
    <view 
      wx:for="{{observeList}}" 
      wx:key="_id"
      class="observe-card"
    >
      <image class="card-cover" src="{{item.coverImage}}" mode="aspectFill" />
      <view class="card-content">
        <view class="card-title">{{item.speciesName}}</view>
        <view class="card-info">
          <text class="info-item">📍 {{item.location}}</text>
          <text class="info-item">🕒 {{item.observeTime}}</text>
        </view>
        <view class="card-bottom">
          <view class="user-info">
            <image class="avatar" src="{{item.avatar}}" />
            <text class="nickname">{{item.nickname}}</text>
          </view>
          <view class="like-info">
            <text>👍 {{item.likeCount}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{observeList.length === 0 && !loading}}" class="empty-box">
      <text class="empty-text">暂无观察记录</text>
    </view>

    <!-- 加载提示 -->
    <view wx:if="{{loading}}" class="loading-box">
      <text>加载中...</text>
    </view>
  </view>

  <!-- 悬浮发布按钮 -->
  <view class="publish-btn" bindtap="goPublish">
    <text class="publish-icon">+</text>
  </view>
</view>