.container {
  min-height: 100vh;
  background-color: #F5F9F0;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 30rpx;
  background-color: #2E7D32;
}
.search-input {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
}
.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}
.search-input input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
.placeholder {
  color: #999;
}

/* 分类标签 */
.tab-scroll {
  white-space: nowrap;
  background-color: #ffffff;
  border-bottom: 1rpx solid #eee;
}
.tab-list {
  display: inline-flex;
  padding: 0 20rpx;
}
.tab-item {
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}
.tab-item.active {
  color: #2E7D32;
  font-weight: 600;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #2E7D32;
  border-radius: 3rpx;
}

/* 观察列表 */
.observe-list {
  padding: 20rpx;
}
.observe-card {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.card-cover {
  width: 100%;
  height: 360rpx;
  display: block;
}
.card-content {
  padding: 24rpx;
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.card-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 20rpx;
}
.info-item {
  font-size: 24rpx;
  color: #888;
}
.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}
.user-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}
.nickname {
  font-size: 24rpx;
  color: #666;
}
.like-info {
  font-size: 24rpx;
  color: #888;
}

/* 空状态 */
.empty-box {
  padding: 120rpx 0;
  text-align: center;
}
.empty-text {
  font-size: 28rpx;
  color: #aaa;
}

/* 加载 */
.loading-box {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #999;
}

/* 悬浮发布按钮 */
.publish-btn {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 110rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(46, 125, 50, 0.4);
  z-index: 999;
}
.publish-icon {
  font-size: 60rpx;
  color: #fff;
  line-height: 1;
  font-weight: 300;
}