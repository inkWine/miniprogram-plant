.container {
  min-height: 100vh;
  background-color: #F5F9F0;
  padding: 30rpx;
  box-sizing: border-box;
  padding-bottom: 120rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 图片上传 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}
.upload-img {
  width: 100%;
  height: 100%;
}
.delete-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  text-align: center;
  line-height: 40rpx;
  font-size: 28rpx;
  border-bottom-left-radius: 12rpx;
}
.add-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #2E7D32;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fff;
}
.add-icon {
  font-size: 60rpx;
  color: #2E7D32;
  line-height: 1;
}
.add-text {
  font-size: 24rpx;
  color: #2E7D32;
  margin-top: 8rpx;
}

/* 表单 */
.form-section {
  margin-top: 40rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
}
.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.form-item:last-child {
  border-bottom: none;
}
.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}
.required {
  color: #e53935;
  margin-left: 4rpx;
}
.input {
  width: 100%;
  font-size: 28rpx;
  color: #333;
  padding: 12rpx 0;
}
.picker-text {
  font-size: 28rpx;
  color: #333;
  padding: 12rpx 0;
}
.location-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.location-input {
  flex: 1;
}
.location-btn {
  font-size: 24rpx;
  color: #2E7D32;
  padding: 8rpx 20rpx;
  border: 1rpx solid #2E7D32;
  border-radius: 30rpx;
  white-space: nowrap;
}
.textarea {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  color: #333;
  padding: 12rpx 0;
}

/* 提交按钮 */
.submit-section {
  margin-top: 60rpx;
}
.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}
.submit-btn[disabled] {
  opacity: 0.6;
}